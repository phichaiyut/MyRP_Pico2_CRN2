
void readme()
  {
    robot.Motor(10 ,10);
    robot.Motor(-10 ,-10);
    robot.Motor(0 ,0);
    
    //--------------------------------->> เซนเซอร์
    //---->> เซนเซอร์หน้า
    robot.read_sensorA(0)                 ;  //ค่าที่อ่านได้จากเซนเซอร์  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.md_sensorA(0)                   ;  //ค่ากลางระหว่างพื้นขาวกับดำ  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.sensorMinA[0]                   ;   //ค่าต่ำสุดได้จากการคาริเบรท ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.sensorMaxA[0]                   ;   //ค่ามากสุดได้จากการคาริเบรท ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา

    //---->> เซนเซอร์หลัง
    robot.read_sensorB(0)                 ;  //ค่าที่อ่านได้จากเซนเซอร์  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.md_sensorB(0)                   ;  //ค่ากลางระหว่างพื้นขาวกับดำ  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.sensorMinB[0]                   ;   //ค่าต่ำสุดได้จากการคาริเบรท ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.sensorMaxB[0]                   ;   //ค่ามากสุดได้จากการคาริเบรท ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา

    //---->> เซนเซอร์กลาง
    
    analogRead(26)                  ;  //ค่าที่อ่านได้จากเซนเซอร์  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.md_sensorC(0)                   ;
    robot.sensorMinC[0]                   ;                
    robot.sensorMaxC[0]                   ; 

    analogRead(27)                  ;  //ค่าที่อ่านได้จากเซนเซอร์  ค่าในวงเล็บ 0-7 เรียงจากซ้ายไปขวา
    robot.md_sensorC(1)                   ;
    robot.sensorMinC[1]                   ;                
    robot.sensorMaxC[1]                   ; 

    //  คำสั่งเดินตามเส้น นับทีละแยก

     robot.sensor_position(50);

     robot.fline(50, 50, 0.25, "30", 'n', 's', 90, "a6", 0);
     robot.fline(40, 40, 0.45, "fl", 'c', 'l', 60, "a1", 10);
     robot.fline(40, 40, 1.25, "fr", 'f', 'l', 90, "a1", 1);
     robot.fline(60, 60, 0.45, "cl", 'c', 'l', 90, "a1", 10);
     robot.fline(40, 40, 0.45, "cr", 'f', 's', 90, "a1", 1);
     robot.fline(40, 40, 0.45, "bl", 'f', 's', 90, "a1", 1);
     robot.fline(40, 40, 0.45, "br", 'f', 's', 90, "a1", 1);

     robot.fw_gyro(30, 30, 1.5,  60, 10);   // ความเร็ว 30 30  kp1.5   ระยะ 60 เซนติเมตร ค่าเบรค 10
     robot.bw_gyro(30, 30, 1.5,  60, 10);   // ความเร็ว 30 30  kp1.5   ระยะ 60 เซนติเมตร ค่าเบรค 10


     robot.rotate(-1, 30, -45, 10) ;  //---> หมุนซ้าย มอเตอร์ ซ้าย -1   ขวา 30 หมุนไปที่ -45 องศา
     robot.rotate(30, -1,  45, 10) ;  //---> หมุนซ้าย มอเตอร์ ซ้าย 30   ขวา -1 หมุนไปที่  45 องศา

     robot.rotate(-30, 30, -45, 10) ;  //---> หมุนซ้าย มอเตอร์ ซ้าย -30   ขวา 30 หมุนไปที่ -45 องศา
     robot.rotate(30, -30,  45, 10) ;  //---> หมุนซ้าย มอเตอร์ ซ้าย 30   ขวา -30 หมุนไปที่  45 องศา

     robot.place_left_in(30, 90, 10) ;  //---> หมุนซ้ายเข้า มอเตอร์ ซ้าย 0   ขวา 30 หมุนไปที่  90 องศา
     robot.place_left_out(30, 90, 10) ; //---> หมุนซ้ายออก มอเตอร์ ซ้าย 0   ขวา 30 หมุนไปที่  90 องศา

     robot.place_right_in(30, 90, 10) ;  //---> หมุนขวาเข้า มอเตอร์ ซ้าย 0   ขวา 30 หมุนไปที่  90 องศา
     robot.place_right_out(30, 90, 10) ; //---> หมุนขวาออก มอเตอร์ ซ้าย 0   ขวา 30 หมุนไปที่  90 องศา

     robot.setrobot_fline(4);    //--->> เซตหุ่นยนต์ให้ตรง โดยใช้เซนเซอร์หน้า แตะเส้นดำ  4 คือ จำนวนครั้งที่เซต
     robot.setrobot_bline(4);    //--->> เซตหุ่นยนต์ให้ตรง โดยใช้เซนเซอร์sหลัง แตะเส้นดำ  4 คือ จำนวนครั้งที่เซต
  
    //----------------------------------------------------------------------------->>
  

  }




